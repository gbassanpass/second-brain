# Cópia local: `cp .env.example .env` (e nunca commite o .env).
# Veja docs/08-setup-and-env.md para a fonte da verdade.

# Core
APP_ENV=dev
APP_PORT=3001
APP_SECRET=change-me

# Supabase (preenchidos automaticamente após `supabase start`)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# `supabase status` → JWT_SECRET. Em prod, copie do dashboard (API > JWT Secret).
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:54322/postgres

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379/0

# LLM / IA
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-haiku
LLM_FALLBACK_MODEL=claude-sonnet
OPENAI_API_KEY=
EMBEDDINGS_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=
RERANK_PROVIDER=cohere
RERANK_MODEL=rerank-v3.5

# Transcrição
TRANSCRIPTION_PROVIDER=deepgram
DEEPGRAM_API_KEY=
# ou ASSEMBLYAI_API_KEY=

# Conectores (Fase 1)
# Scraper de conteúdo público (Instagram por handle, F1.11)
# SCRAPER_PROVIDER: `apify` (real) ou `fake` (dev/testes). Token em apify.com (tier grátis).
SCRAPER_PROVIDER=fake
APIFY_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify~instagram-scraper
INSTAGRAM_RESULTS_LIMIT=30

PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
PHYLLO_ENV=sandbox

# Voz (Fase 1)
ELEVENLABS_API_KEY=

# Billing
# BILLING_PROVIDER: `stripe` (default em dev/prod) ou `fake` (testes).
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend (Next.js) — URL do backend Hono visível ao app.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Supabase Auth no browser (magic link). URL local + anon key de `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Billing (checkout E6.3): preço recorrente + URL pública do app p/ retorno.
STRIPE_PRICE_ID=
PUBLIC_APP_URL=http://localhost:3000

# Limites/custo
MAX_TOKENS_PER_REPLY=800
RETRIEVAL_TOP_K=5
RERANK_SCORE_THRESHOLD=0.2
