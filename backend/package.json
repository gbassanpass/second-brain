{
  "name": "@second-brain/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ingest-fausto": "tsx src/scripts/ingest-fausto.ts",
    "seed": "tsx src/scripts/seed.ts",
    "retrieval-smoke": "tsx src/scripts/retrieval-smoke.ts",
    "prompt-smoke": "tsx src/scripts/prompt-smoke.ts",
    "worker:ingest": "tsx src/scripts/worker-ingest.ts",
    "worker:ingest:watch": "tsx watch src/scripts/worker-ingest.ts",
    "eval": "tsx src/scripts/eval.ts"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "bullmq": "^5.79.1",
    "dotenv": "16.4.5",
    "drizzle-orm": "0.36.4",
    "drizzle-zod": "0.5.1",
    "hono": "4.6.12",
    "postgres": "3.4.5",
    "unpdf": "^1.6.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
